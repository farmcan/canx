#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LIB_FILE="$ROOT_DIR/lib/codex_fork.sh"
GHOSTTY_BIN="$ROOT_DIR/bin/codex-fork-ghostty"

source "$LIB_FILE"

usage() {
  cat <<'EOF'
Usage:
  codex-fork-here <task-text> [output-dir]

Behavior:
  1. Detect the newest Codex session whose cwd matches the current directory.
  2. Delegate to the Ghostty launcher with that session file.
EOF
}

main() {
  if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage
    return 0
  fi

  if [[ $# -lt 1 || $# -gt 2 ]]; then
    usage >&2
    return 1
  fi

  local task_text="$1"
  local output_dir="${2:-$ROOT_DIR/runs/$(date +%Y%m%d-%H%M%S)}"
  local session_file

  session_file="$(latest_session_file_for_cwd "$PWD")"
  if [[ -z "$session_file" ]]; then
    echo "no Codex session file found for cwd: $PWD" >&2
    return 1
  fi

  echo "detected session file: $session_file"
  bash "$GHOSTTY_BIN" "$session_file" "$task_text" "$output_dir"
}

main "$@"
